{
  "name": "cc-status-dash",
  "version": "0.1.0",
  "description": "A feature-rich Claude Code statusline + HUD: widget formatter (ccstatusline-style) fused with live tool/agent/todo activity (Claude HUD-style). Bun-first, Node-compatible.",
  "type": "module",
  "module": "dist/index.js",
  "bin": {
    "cc-status-dash": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "bun build src/index.ts --target=node --outdir=dist --splitting --external react-devtools-core",
    "build:node": "tsc -p tsconfig.json",
    "dev": "bun build src/index.ts --target=node --outdir=dist --splitting --external react-devtools-core --watch",
    "start": "bun run src/index.ts",
    "demo": "bun run src/index.ts < sample-input.json",
    "demo:node": "node dist/index.js < sample-input.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test src",
    "test:node": "npm run build:node && node --test dist/__tests__/*.test.js",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18"
  },
  "dependencies": {
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@clack/prompts": "^1.6.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "ink": "^7.1.0",
    "ink-testing-library": "^4.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3"
  },
  "keywords": ["claude-code", "statusline", "hud", "powerline", "cli", "terminal", "bun"],
  "license": "MIT",
  "files": ["dist", "commands", ".claude-plugin", "README.md"]
}
